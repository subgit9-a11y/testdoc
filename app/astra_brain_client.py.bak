"""
Astra Brain Client - Unified API Connector for api.ayureze.in
Version: 4.2.0 - Fixed Routing Edition
"""

import logging
import httpx
import asyncio
import json
from typing import Optional, Dict, Any, List
from dataclasses import dataclass
from enum import Enum

logger = logging.getLogger(__name__)

# ============================================================================
# Data Models
# ============================================================================

class Intent(str, Enum):
    CHAT = "CHAT"
    SHOP_ASSIST = "SHOP_ASSIST"
    BOOKING = "BOOKING"
    UNKNOWN = "UNKNOWN"

@dataclass
class ChatResponse:
    answer: str
    mode: str
    success: bool = True

@dataclass
class AutopilotResponse:
    intent: Intent
    status: str
    confidence: float = 1.0

@dataclass
class SafetyAnalysis:
    is_safe: bool
    flags: List[str]
    risk_level: str = "low"

@dataclass
class EmotionResult:
    emotion: str
    intensity: str
    confidence: float = 0.8

@dataclass
class ScheduleResult:
    reminders: List[Dict[str, Any]]
    raw_json: str

# ============================================================================
# Main Client
# ============================================================================

class AstraBrainClient:
    def __init__(self, base_url: str = "https://api.ayureze.in"):
        self.base_url = base_url.rstrip("/")
        # The unified prefix for all Brain endpoints
        self.api_prefix = f"{self.base_url}/api/v1/brain" 
        
        # Optimize performance: reuse HTTP connection pools
        limits = httpx.Limits(max_keepalive_connections=20, max_connections=50)
        self.timeout = httpx.Timeout(60.0, read=60.0, connect=10.0)
        
        self.client = httpx.AsyncClient(timeout=self.timeout, limits=limits)
        self._connected = False
        logger.info(f"🧠 AstraBrainClient optimized and initialized → {self.api_prefix}")

    async def close(self):
        """Clean up connections on shutdown"""
        await self.client.aclose()

    async def check_health(self) -> Dict[str, Any]:
        try:
            async with httpx.AsyncClient(timeout=10.0) as client:
                # Updated to hit the brain's specific health endpoint
                response = await client.get(f"{self.api_prefix}/health")
                if 200 <= response.status_code < 300:
                    self._connected = True
                    return {"status": "online"}
                return {"status": "degraded", "code": response.status_code}
        except Exception as e:
            return {"status": "offline", "error": str(e)}

    async def chat(self, query: str, language: str = "en") -> ChatResponse:
        try:
            response = await self.client.post(f"{self.api_prefix}/chat", json={"query": query, "language": language})
            response.raise_for_status()
            data = response.json()
            
            if not data.get("success", True):
                return ChatResponse(answer=data.get("answer", "Unknown error formatting response"), mode="error", success=False)
                raw_answer = data.get("answer", data.get("response", ""))
                return ChatResponse(
                    answer=raw_answer.replace("[SYSTEM]:", "").strip(),
                    mode=data.get("mode", "chat"),
                    success=True
                )
        except Exception as e:
            logger.error(f"❌ Chat API Failed: {e}")
            return ChatResponse(answer="I'm having trouble connecting to the brain.", mode="error", success=False)

    async def autopilot(self, query: str) -> AutopilotResponse:
        try:
            async with httpx.AsyncClient(timeout=self.timeout) as client:
                response = await client.post(f"{self.api_prefix}/autopilot", json={"query": query})
                data = response.json()
                intent_val = data.get("intent", "CHAT").upper()
                try:
                    intent = Intent(intent_val)
                except ValueError:
                    intent = Intent.CHAT
                return AutopilotResponse(intent=intent, status="success")
        except Exception:
            return AutopilotResponse(intent=Intent.CHAT, status="error")

    async def fill(self, text: str, schema_definition: str) -> Dict[str, Any]:
        try:
            async with httpx.AsyncClient(timeout=self.timeout) as client:
                response = await client.post(f"{self.api_prefix}/fill", json={"text": text, "schema_definition": schema_definition})
                return {"success": response.status_code == 200, "extracted_data": response.json().get("extracted_data", "{}")}
        except Exception as e:
            return {"success": False, "error": str(e)}

    async def shop_assist(self, query: str) -> Dict[str, Any]:
        try:
            async with httpx.AsyncClient(timeout=self.timeout) as client:
                response = await client.post(f"{self.api_prefix}/shop_assist", json={"query": query})
                return {"success": response.status_code == 200, "result": response.json().get("result", "{}")}
        except Exception as e:
            return {"success": False, "error": str(e)}

    async def extract_schedule(self, prescription_text: str) -> ScheduleResult:
        try:
            async with httpx.AsyncClient(timeout=self.timeout) as client:
                response = await client.post(f"{self.api_prefix}/extract_schedule", json={"prescription_text": prescription_text})
                if response.status_code == 200:
                    data = response.json()
                    schedule_json = data.get("schedule_json", "{}")
                    parsed = json.loads(schedule_json) if schedule_json else {}
                    return ScheduleResult(reminders=parsed.get("reminders", []), raw_json=schedule_json)
                return ScheduleResult(reminders=[], raw_json="{}")
        except Exception:
            return ScheduleResult(reminders=[], raw_json="{}")

    async def doctor_summary(self, patient_notes: str) -> Dict[str, Any]:
        try:
            async with httpx.AsyncClient(timeout=self.timeout) as client:
                response = await client.post(f"{self.api_prefix}/doctor_summary", json={"patient_notes": patient_notes})
                return {"success": response.status_code == 200, "summary": response.json().get("summary_data", "")}
        except Exception as e:
            return {"success": False, "error": str(e)}

    async def analyze_safety(self, user_text: str) -> SafetyAnalysis:
        try:
            async with httpx.AsyncClient(timeout=self.timeout) as client:
                response = await client.post(f"{self.api_prefix}/analyze_safety", json={"user_text": user_text})
                d = response.json()
                return SafetyAnalysis(is_safe=d.get("is_safe", True), flags=d.get("flags", []))
        except Exception:
            return SafetyAnalysis(is_safe=True, flags=[], risk_level="unknown")

    async def detect_emotion(self, query: str) -> EmotionResult:
        try:
            async with httpx.AsyncClient(timeout=self.timeout) as client:
                response = await client.post(f"{self.api_prefix}/detect_emotion", json={"query": query})
                data = response.json()
                res_field = data.get("result", "{}")
                res = json.loads(res_field) if isinstance(res_field, str) else res_field
                return EmotionResult(emotion=res.get("emotion", "Neutral"), intensity=res.get("intensity", "Medium"))
        except Exception:
            return EmotionResult(emotion="Neutral", intensity="Medium")

    async def profile_analysis(self, profile_data_a: str, task: str = "buddy_match", profile_data_b: Optional[str] = None) -> Dict[str, Any]:
        try:
            payload = {"profile_data_a": profile_data_a, "task": task}
            if profile_data_b: payload["profile_data_b"] = profile_data_b
            async with httpx.AsyncClient(timeout=self.timeout) as client:
                response = await client.post(f"{self.api_prefix}/profile_analysis", json=payload)
                return {"success": response.status_code == 200, "analysis": response.json().get("analysis", "")}
        except Exception as e:
            return {"success": False, "error": str(e)}

    async def generate_wellness(self, topic: str, duration: str = "5 mins") -> Dict[str, Any]:
        try:
            async with httpx.AsyncClient(timeout=self.timeout) as client:
                response = await client.post(f"{self.api_prefix}/generate_wellness", json={"topic": topic, "duration": duration})
                return {"success": response.status_code == 200, "content": response.json().get("content", "")}
        except Exception as e:
            return {"success": False, "error": str(e)}

    async def adjust_tone(self, text: str, target_tone: str = "polite") -> Dict[str, Any]:
        try:
            async with httpx.AsyncClient(timeout=self.timeout) as client:
                response = await client.post(f"{self.api_prefix}/adjust_tone", json={"text": text, "target_tone": target_tone})
                return {"success": response.status_code == 200, "rewritten_text": response.json().get("rewritten_text", text)}
        except Exception as e:
            return {"success": False, "rewritten_text": text, "error": str(e)}

# =========================================================================
# Singleton Instance & Dependency Injection
# =========================================================================

_brain_client = None

def get_brain_client() -> AstraBrainClient:
    """Provides a singleton instance of the AstraBrainClient"""
    global _brain_client
    if _brain_client is None:
        _brain_client = AstraBrainClient()
    return _brain_client

astra_brain = get_brain_client()

# =========================================================================
# Server Endpoints
# =========================================================================

from fastapi import APIRouter
from pydantic import BaseModel as _BaseModel

brain_router = APIRouter(prefix="/api/v1/brain", tags=["brain"])

class ShopAssistRequest(_BaseModel):
    query: str
    context: Optional[str] = None

class ExtractScheduleRequest(_BaseModel):
    prescription_text: str

@brain_router.get("/health")
async def brain_health_check() -> Dict[str, Any]:
    """Health check endpoint for the gateway."""
    return {"status": "online"}

@brain_router.post("/shop_assist")
async def brain_shop_assist(request: ShopAssistRequest) -> Dict[str, Any]:
    """Endpoint for shop assist."""
    # Mock Response
    mock_result_data = {
        "products_found": ["Triphala Churna", "Ashwagandha"],
        "recommendation": "Based on your query, here is an Ayurvedic recommendation."
    }
    return {
        "success": True,
        "result": json.dumps(mock_result_data)
    }

@brain_router.post("/extract_schedule")
async def brain_extract_schedule(request: ExtractScheduleRequest) -> Dict[str, Any]:
    """Endpoint for schedule extraction."""
    # Mock Response
    mock_schedule_data = {
        "reminders": [
            {
                "medicine": "Ashwagandha",
                "time": "morning",
                "dosage": "1 tablet",
                "instructions": "Take with warm milk"
            }
        ],
        "notes": "Extracted from prescription"
    }
    return {
        "schedule_json": json.dumps(mock_schedule_data)
    }

# Standalone execution for testing
if __name__ == "__main__":
    import uvicorn
    from fastapi import FastAPI
    app = FastAPI(title="Astra Brain - Mockup Mode")
    app.include_router(brain_router)
    # The frontend is calling api.ayureze.in. We can run this directly on port 5005
    uvicorn.run(app, host="0.0.0.0", port=5005)
