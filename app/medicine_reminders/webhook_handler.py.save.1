async def send_welcome(phone: str, name: str):
    from app.medicine_reminders.custom_whatsapp_client import CustomWhatsAppClient
    msg = WELCOME_MESSAGE.format(name=name, **EMOJI)
    await CustomWhatsAppClient().send_text_message(phone, msg)

async def send_help(phone: str):
    from app.medicine_reminders.custom_whatsapp_client import CustomWhatsAppClient
    msg = HELP_MESSAGE.format(**EMOJI)
    await CustomWhatsAppClient().send_text_message(phone, msg)

async def handle_medicine_response(phone: str, response: str):
    from app.medicine_reminders.reminder_engine import ReminderEngine
    from app.medicine_reminders.custom_whatsapp_client import CustomWhatsAppClient

    ReminderEngine().handle_patient_response(
        patient_phone=phone,
        response=response,
        message_timestamp=datetime.utcnow().isoformat()
    )

    msg = CONFIRMATION_MESSAGES.get(response, "Recorded").format(**EMOJI)
    await CustomWhatsAppClient().send_text_message(phone, msg)

async def handle_ai_query(phone: str, query: str):
    from app.medicine_reminders.custom_whatsapp_client import CustomWhatsAppClient

    ai_response = None
    try:
        from app.enhanced_inference import model_inference
        if model_inference:
            ai_response = await model_inference.generate_response(query)
    except Exception:
        logger.exception("AI inference failed")

    if not ai_response:
        ai_response = "🌿 I’m checking our Ayurvedic knowledge base. Please wait."

    await CustomWhatsAppClient().send_text_message(phone, ai_response)

async def handle_search(phone: str, medicine: str):
    from app.medicine_reminders.custom_whatsapp_client import CustomWhatsAppClient
    await CustomWhatsAppClient().send_text_message(
        phone,
        f"🔍 Searching for medicine: {medicine}"
    )

async def send_text(phone: str, text: str):
    from app.medicine_reminders.custom_whatsapp_client import CustomWhatsAppClient
    await CustomWhatsAppClient().send_text_message(phone, text)
